# Copy this file to .env and fill in your details.
# .env is gitignored and will never be committed.

# -- Datos personales (obligatorios) ------------------------------------------
NAME=APELLIDO1 APELLIDO2 NOMBRE
DNI=12345678X
PHONE=600000000

# -- Anos a declarar ----------------------------------------------------------
CURRENT_YEAR=2025
PREVIOUS_YEAR=2024

# -- Numero de justificante ---------------------------------------------------
# 13 digitos. Debe empezar por 720 y NO puede ser todo ceros al presentar por
# fichero (TGVI Online). El valor por defecto (720{ano}000001) es valido.
# JUSTIFICANTE=7202025000001

# -- Rutas y nombre de archivo (opcionales) -----------------------------------
# INPUT_DIR=input
# OUTPUT_DIR=output
# OUTPUT_FILENAME=modelo_720.720
# CSV_DELIMITER=,
